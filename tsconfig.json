{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler (Vite) owns the actual transpile; tsc only type-checks. Explicit
       .ts/.tsx import extensions are allowed so the codebase keeps its existing
       extension-in-specifier house style during the JS -> TS migration. */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Incremental migration: legacy .js/.jsx is allowed to coexist and is NOT
       type-checked (checkJs:false). New .ts/.tsx is held to strict. As files
       are converted they opt into full checking automatically. */
    "allowJs": true,
    "checkJs": false,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"]
}
